# Copy only the variables needed by your chosen provider into your shell.
# This file is documentation; the project does not automatically load it.

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Local or self-hosted OpenAI-compatible endpoint
LOCAL_MODEL_API_KEY=local-no-key-required
OPENAI_API_BASE=http://127.0.0.1:8000/v1

# Ollama normally needs no key and defaults to localhost.
OLLAMA_API_BASE=http://127.0.0.1:11434
